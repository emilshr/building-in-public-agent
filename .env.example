# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/building_in_public

# ─── Encryption ──────────────────────────────────────────────────────────────
# Used to derive per-user encryption keys for API key storage (BYOK).
# Must be at least 32 characters. Generate with: openssl rand -base64 48
ENCRYPTION_SECRET=

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Secret used for session signing. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# The base URL of the web app (used for OAuth redirects)
BETTER_AUTH_URL=http://localhost:3000

# ─── GitHub OAuth (for Better Auth social login) ─────────────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set the callback URL to: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── GitHub App (for repo access) ───────────────────────────────────────────
# Create a GitHub App at: https://github.com/settings/apps
# Required permissions: Contents: Read
# Webhook URL: {BETTER_AUTH_URL}/api/github/webhook
# Webhook secret: generate with `openssl rand -hex 32`
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── Twitter/X (for content posting) ────────────────────────────────────────
# Create a Twitter Developer App at: https://developer.twitter.com
# Enable OAuth 2.0 with PKCE, set callback URL to: {BETTER_AUTH_URL}/api/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Inngest ─────────────────────────────────────────────────────────────────
# Optional in development (Inngest Dev Server auto-discovers)
# Required in production — get from https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
